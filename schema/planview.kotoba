// Planview clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace planview {

    entity Record {
        id: string @unique
        name: string
        type: string
        ownerId: string
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Matter {
        id: string @unique
        clientId: string
        title: string
        status: string
        openedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Contract {
        id: string @unique
        counterparty: string
        value: float
        status: string
        signedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Course {
        id: string @unique
        title: string
        term: string
        enrollment: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Property {
        id: string @unique
        address: string
        units: integer
        value: float
        createdAt: datetime
        updatedAt: datetime
    }

    entity Document {
        id: string @unique
        recordId: string
        name: string
        contentRef: string
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
